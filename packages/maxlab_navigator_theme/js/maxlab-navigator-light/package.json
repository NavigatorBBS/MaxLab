{
  "name": "@navigatorbbs/maxlab-navigator-light",
  "version": "0.1.0",
  "description": "NavigatorBBS-inspired light theme for MaxLab.",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "jupyterlab-theme",
    "maxlab"
  ],
  "license": "MIT",
  "author": "NavigatorBBS",
  "files": [
    "lib/**/*.{d.ts,js,js.map}",
    "style/**/*.{css,png,svg}",
    "src/**/*.ts"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "npm run build:lib && npm run build:labextension:dev",
    "build:prod": "npm run clean && npm run build:lib:prod && npm run build:labextension",
    "build:labextension": "jupyter labextension build . && npm run fix:metadata",
    "build:labextension:dev": "jupyter labextension build --development True . && npm run fix:metadata",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "clean": "rimraf lib tsconfig.tsbuildinfo ../../maxlab_navigator_theme/labextensions/@navigatorbbs/maxlab-navigator-light",
    "fix:metadata": "python ../../scripts/normalize_labextension_metadata.py ../../maxlab_navigator_theme/labextensions/@navigatorbbs/maxlab-navigator-light/package.json",
    "watch": "tsc -w --sourceMap"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/translation": "^4.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "rimraf": "^5.0.5",
    "typescript": "~5.9.3"
  },
  "sideEffects": true,
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "../../maxlab_navigator_theme/labextensions/@navigatorbbs/maxlab-navigator-light",
    "themePath": "style/index.css"
  }
}
